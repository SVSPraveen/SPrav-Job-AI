# ──────────────────────────────────────────────────────────────
# SPrav MoE Pipeline — Environment Variables
# Copy this to .env and fill in the values.
# ──────────────────────────────────────────────────────────────

# JWT auth secret (set this to a long random string)
JWT_SECRET=change_me_to_a_long_random_string

# (Optional) Cloud LLM fallback keys — only needed if mode.yaml is not 'local'
GROQ_API_KEY=your_groq_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# (Optional) SMTP Email Notifications
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
EMAIL_RECEIVER=your_email@gmail.com

# ──────────────────────────────────────────────────────────────
# Auto-Apply Gating Thresholds
# ──────────────────────────────────────────────────────────────

# ATS keyword coverage score required to be eligible for auto-apply (0.0–1.0)
# A job scoring below this goes to the Human Apply Queue even if the fit score passes.
ATS_AUTO_APPLY_THRESHOLD=0.88

# DeepSeek-R1 fit score required to be eligible for auto-apply (1.0–5.0)
FIT_AUTO_APPLY_THRESHOLD=4.0

# Maximum auto-applications to a single company per calendar day.
# Exceeding this routes the job to Human Apply Queue with status 'company_cap_reached'.
COMPANY_DAILY_CAP=3

# Number of consecutive Playwright submission failures before the auto-apply loop
# is paused and a dashboard alert is raised. Counter is persisted to DB.
AUTO_APPLY_CIRCUIT_BREAKER_N=3

# ──────────────────────────────────────────────────────────────
# LinkedIn Post Scanner
# Credentials for the headless browser to log into LinkedIn and
# scan HR/CEO posts for informal hiring announcements.
# ──────────────────────────────────────────────────────────────
LINKEDIN_EMAIL=your_linkedin_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password

# ──────────────────────────────────────────────────────────────
# Gmail Send (for LinkedIn post auto-email applications)
# The gmail_tracker.py scope now includes gmail.send.
# Delete token.json and re-authorize once to activate send capability.
# ──────────────────────────────────────────────────────────────
# (No new keys needed — uses the same credentials.json OAuth flow)
